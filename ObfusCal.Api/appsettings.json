{
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "00000000-0000-0000-0000-000000000000",
    "Domain": "example.onmicrosoft.com",
    "ClientId": "00000000-0000-0000-0000-000000000000"
  },
  "GraphConsent": {
    "ApiBaseUrl": "https://graph.microsoft.com",
    "ReadOnlyScope": "https://graph.microsoft.com/Calendars.Read offline_access",
    "ReadWriteScope": "https://graph.microsoft.com/Calendars.ReadWrite offline_access",
    "Scope": "https://graph.microsoft.com/Calendars.ReadWrite offline_access",
    "AuthorityTenant": "common",
    "ClientId": "00000000-0000-0000-0000-000000000000",
    "ClientSecret": ""
  },
  "GoogleConsent": {
    "ApiBaseUrl": "https://www.googleapis.com",
    "AuthorizationEndpoint": "https://accounts.google.com/o/oauth2/v2/auth",
    "TokenEndpoint": "https://oauth2.googleapis.com/token",
    "Scope": "https://www.googleapis.com/auth/calendar.events",
    "ClientId": "000000000000-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa.apps.googleusercontent.com",
    "ClientSecret": ""
  },
  "Calendar": {
    "Provider": "Graph"
  },
  "Sync": {
    "InstanceId": "obfuscal-instance",
    "ApiKey": "",
    "PeerRequestTimestampToleranceSeconds": 300,
    "SyncIntervalSeconds": 900,
    "LookAheadDays": 14,
    "MaxQueryWindowDays": 90,
    "MaxShadowSlotsPerRequest": 500,
    "PeerRequestRateLimitPermitLimit": 240,
    "PeerRequestRateLimitWindowSeconds": 60,
    "PushShadowSlotsRateLimitPermitLimit": 60,
    "PushShadowSlotsRateLimitWindowSeconds": 60,
    "PullBusySlotsRateLimitPermitLimit": 120,
    "PullBusySlotsRateLimitWindowSeconds": 60,
    "MaxRequestBodySizeBytes": 1048576,
    "ShadowSlotRetentionDays": 90,
    "WriteBackLookAheadDays": 90,
    "WriteBackPlaceholderTitle": "Busy"
  },
  "PeerTransportSecurity": {
    "AllowSelfSignedCerts": false
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.Components.Server.Circuits.RemoteNavigationManager": "Fatal"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext"]
  }
}
