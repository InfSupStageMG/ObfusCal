@page "/sync-status"
@using ObfusCal.Application.Interfaces
@inject IPeerConnectionService PeerConnectionService
@inject IOutboundPeerSyncService OutboundSyncService
@inject IInboundPeerPullSyncService InboundSyncService

<PageTitle>Sync Status - ObfusCal</PageTitle>

<h1>Sync Status</h1>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
    <section class="card">
        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
            <FluentButton Appearance="Appearance.Accent" OnClick="RefreshAsync">
                Refresh
            </FluentButton>
            <FluentButton Appearance="Appearance.Outline" OnClick="TriggerSyncAsync" Disabled="_syncing">
                @(_syncing ? "Syncing..." : "Trigger Sync Now")
            </FluentButton>
        </FluentStack>
        @if (_syncMessage is not null)
        {
            <FluentMessageBar Intent="MessageIntent.Success">
                @_syncMessage
            </FluentMessageBar>
        }
    </section>

    @if (_loading)
    {
        <FluentProgress/>
    }
    else if (_peers is not null)
    {
        <section class="card">
            <FluentDataGrid Items="_peers.AsQueryable()" TGridItem="PeerSyncStatus">
                <PropertyColumn Property="@(p => p.InstanceId)" Title="Peer Instance" Sortable="true"/>
                <PropertyColumn Property="@(p => p.BaseAddress)" Title="Base Address"/>
                <TemplateColumn Title="Status">
                    @switch (context.LastSyncSucceeded)
                    {
                        case true:
                            <FluentBadge Appearance="Appearance.Accent" Color="Color.Success">Healthy</FluentBadge>
                            break;
                        case false:
                            <FluentBadge Appearance="Appearance.Accent" Color="Color.Error">Failed</FluentBadge>
                            break;
                        default:
                            <FluentBadge Appearance="Appearance.Neutral">Never synced</FluentBadge>
                            break;
                    }
                </TemplateColumn>
                <PropertyColumn Property="@(p => p.LastSyncedAt)" Title="Last Synced" Format="yyyy-MM-dd HH:mm:ss"/>
            </FluentDataGrid>
        </section>
    }
</FluentStack>

@code {
    private List<PeerSyncStatus>? _peers;
    private bool _loading = true;
    private bool _syncing;
    private string? _syncMessage;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        _loading = true;
        _peers = (await PeerConnectionService.ListSyncStatusAsync()).ToList();
        _loading = false;
    }

    private async Task TriggerSyncAsync()
    {
        _syncing = true;
        _syncMessage = null;
        StateHasChanged();

        try
        {
            await OutboundSyncService.RunSyncCycleAsync(CancellationToken.None);
            await InboundSyncService.RunSyncCycleAsync(CancellationToken.None);
            _syncMessage = $"Sync completed at {DateTimeOffset.UtcNow:HH:mm:ss} UTC.";
        }
        catch (Exception ex)
        {
            _syncMessage = $"Sync failed: {ex.Message}";
        }
        finally
        {
            _syncing = false;
            await RefreshAsync();
        }
    }
}


