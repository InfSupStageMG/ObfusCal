@page "/calendar-owners/{Id:guid}"
@using ObfusCal.Application.Interfaces
@using Microsoft.FluentUI.AspNetCore.Components
@inject ICalendarOwnerService CalendarOwnerService
@inject ICalendarSourceCatalog CalendarSourceCatalog
@inject ICalendarSourceInstanceService CalendarSourceInstanceService
@inject ICalendarOwnerGoogleConsentService GoogleConsentService
@inject ICalendarOwnerGraphConsentService GraphConsentService
@inject ICalendarOwnerObfuscationProfileService ObfuscationProfileService
@inject ICalendarOwnerAvailabilitySyncService AvailabilitySyncService
@inject NavigationManager Navigation

<PageTitle>Calendar Owner - ObfusCal</PageTitle>

<FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Center">
    <FluentButton Appearance="Appearance.Lightweight" OnClick="@(() => Navigation.NavigateTo("/calendar-owners"))">
        ← Back
    </FluentButton>
    <h1>@(_owner?.Name ?? "Calendar Owner")</h1>
</FluentStack>

@if (_owner is null)
{
    <FluentProgress/>
}
else
{
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="24">

        <section class="card">
            <h3>Availability Sync</h3>
            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8"
                         VerticalAlignment="VerticalAlignment.Center">
                <FluentButton Appearance="Appearance.Outline" OnClick="TriggerOwnerSyncAsync"
                              Disabled="_triggeringSyncForOwner">
                    @(_triggeringSyncForOwner ? "Syncing…" : "Trigger Sync Now")
                </FluentButton>
            </FluentStack>
            @if (_ownerSyncMessage is not null)
            {
                <FluentMessageBar Intent="@_ownerSyncMessageIntent">
                    @_ownerSyncMessage
                </FluentMessageBar>
            }
        </section>

        <section class="card">
            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Center" Class="section-header-box">
                <h3 class="header-title-flex">Calendar Sources</h3>
                @if (_pluginOptions.Count > 0)
                {
                    <FluentButton Appearance="@(_showAddForm ? Appearance.Outline : Appearance.Accent)"
                                  OnClick="@(() => { _showAddForm = !_showAddForm; _sourceMessage = null; })">
                        @(_showAddForm ? "Cancel" : "+ Add Source")
                    </FluentButton>
                }
            </FluentStack>

            @if (_pluginOptions.Count == 0)
            {
                <FluentMessageBar Intent="MessageIntent.Warning">
                    No calendar source plugins were discovered. Drop plugin assemblies in the <code>plugins</code> folder and restart.
                </FluentMessageBar>
            }

            @if (_showAddForm)
            {
                <section class="card source-form-container">
                    <h4 class="source-form-title">New Calendar Source</h4>
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                        <FluentSelect TOption="PluginOption"
                                      Items="_pluginOptions"
                                      OptionValue="@(option => option.Id)"
                                      OptionText="@(option => option.DisplayLabel)"
                                      @bind-SelectedOption="SelectedPluginOption"/>

                        <FluentTextField @bind-Value="_newSourceDisplayName" Immediate="true"
                                         Label="Display name" Placeholder="My calendar"/>

                        @if (HasFieldEditors(_newSourceConfigurationFields))
                        {
                            <h4 class="section-heading">Configuration</h4>
                            @foreach (var field in _newSourceConfigurationFields)
                            {
                                var f = field;
                                <div @key="f.Key" class="config-field">
                                    <label>@f.Label</label>
                                    <input type="text"
                                           @key="@($"cfg-new-{f.Key}")"
                                           class="form-input"
                                           placeholder="@(f.Placeholder ?? "")"
                                           value="@f.Value"
                                           @oninput="@(e => f.Value = e.Value?.ToString())"/>
                                </div>
                            }
                        }
                        else if (!string.IsNullOrWhiteSpace(_newSourceConfigurationJson))
                        {
                            <FluentLabel>Configuration JSON</FluentLabel>
                            <textarea class="config-textarea" @bind="_newSourceConfigurationJson"></textarea>
                        }

                        @if (HasFieldEditors(_newSourceSecretFields))
                        {
                            <h4 class="section-heading">Secrets</h4>
                            @foreach (var field in _newSourceSecretFields)
                            {
                                var f = field;
                                <div @key="f.Key" class="secret-field">
                                    <label>@f.Label</label>
                                    <input type="password"
                                           @key="@($"sec-new-{f.Key}")"
                                           class="form-input"
                                           placeholder="@(f.Placeholder ?? "")"
                                           @oninput="@(e => f.Value = e.Value?.ToString())"/>
                                </div>
                            }
                        }
                        else if (!string.IsNullOrWhiteSpace(_newSourceSecretDataJson))
                        {
                            <FluentLabel>Secret JSON</FluentLabel>
                            <textarea class="secret-textarea" @bind="_newSourceSecretDataJson"></textarea>
                        }

                        @if (!string.IsNullOrWhiteSpace(_selectedPluginOption?.SetupHint))
                        {
                            <FluentMessageBar Intent="MessageIntent.Info">@_selectedPluginOption.SetupHint</FluentMessageBar>
                        }

                        <FluentCheckbox @bind-Value="_newSourceIsEnabled" Label="Enabled"/>
                        <FluentButton Appearance="Appearance.Accent" OnClick="CreateSourceInstanceAsync"
                                      Disabled="@(_selectedPluginOption is null || _creatingSourceInstance)">
                            @(_creatingSourceInstance ? "Adding..." : "Add Source")
                        </FluentButton>

                        @if (_sourceMessage is not null && _lastActionInstanceId is null)
                        {
                            <FluentMessageBar Intent="@_sourceMessageIntent">@_sourceMessage</FluentMessageBar>
                        }
                    </FluentStack>
                </section>
            }

            @* Success message after add (form is now closed) *@
            @if (_sourceMessage is not null && _lastActionInstanceId is null && !_showAddForm)
            {
                <FluentMessageBar Intent="@_sourceMessageIntent">@_sourceMessage</FluentMessageBar>
            }

            @if (_sourceInstances.Count > 0)
            {
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="12" Class="source-section-margin">
                    @foreach (var instance in _sourceInstances)
                    {
                        <section class="card source-instance-container" @key="instance.Id">
                            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8"
                                         VerticalAlignment="VerticalAlignment.Center">
                                <h4 class="source-instance-title">@instance.DisplayName</h4>
                                <FluentBadge Appearance="Appearance.Neutral">@instance.PluginDisplayName</FluentBadge>
                                @if (instance.IsReady)
                                {
                                    <FluentBadge Appearance="Appearance.Accent" Color="Color.Success">Ready</FluentBadge>
                                }
                                else
                                {
                                    <FluentBadge Appearance="Appearance.Neutral">Not Ready</FluentBadge>
                                }
                            </FluentStack>

                            <p class="instance-info-paragraph"><strong>@instance.Title</strong></p>
                            @if (!string.IsNullOrWhiteSpace(instance.Detail))
                            {
                                <p class="instance-detail-paragraph">@instance.Detail</p>
                            }

                            <FluentStack Orientation="Orientation.Vertical" VerticalGap="8" Class="instance-actions-stack">
                                <FluentTextField @bind-Value="instance.DisplayName" Immediate="true" Label="Display name"/>

                                @if (HasFieldEditors(instance.ConfigurationFields))
                                {
                                    <h4 class="section-heading">Configuration</h4>
                                    @foreach (var field in instance.ConfigurationFields)
                                    {
                                        var f = field;
                                        <div @key="f.Key" class="config-field">
                                            <label>@f.Label</label>
                                            <input type="text"
                                                   @key="@($"cfg-{instance.Id}-{f.Key}")"
                                                   class="form-input"
                                                   placeholder="@(f.Placeholder ?? "")"
                                                   value="@f.Value"
                                                   @oninput="@(e => f.Value = e.Value?.ToString())"/>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <FluentLabel>Configuration JSON</FluentLabel>
                                    <textarea class="config-textarea" @bind="instance.ConfigurationJson"></textarea>
                                }

                                @if (HasFieldEditors(instance.SecretFields))
                                {
                                    <h4 class="section-heading">Secrets</h4>
                                    <p style="margin: 0 0 0.25rem; font-size: 0.8rem; color: var(--neutral-foreground-hint);">
                                        Leave blank to keep the existing saved value.
                                    </p>
                                    @foreach (var field in instance.SecretFields)
                                    {
                                        var f = field;
                                        <div @key="f.Key" class="secret-field">
                                            <label>@f.Label</label>
                                            <input type="password"
                                                   @key="@($"sec-{instance.Id}-{f.Key}")"
                                                   class="form-input"
                                                   placeholder="Enter new value to update"
                                                   @oninput="@(e => f.Value = e.Value?.ToString())"/>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <FluentLabel>Secret JSON</FluentLabel>
                                    <textarea class="secret-textarea" @bind="instance.SecretDataJson"></textarea>
                                }

                                <FluentCheckbox @bind-Value="instance.IsEnabled" Label="Enabled"/>

                                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
                                    <FluentButton Appearance="Appearance.Accent"
                                                  OnClick="@(() => UpdateSourceInstanceAsync(instance))"
                                                  Disabled="_updatingSourceInstanceId == instance.Id">
                                        @(_updatingSourceInstanceId == instance.Id ? "Saving..." : "Save")
                                    </FluentButton>
                                    <FluentButton Appearance="Appearance.Outline"
                                                  OnClick="@(() => DeleteSourceInstanceAsync(instance.Id))"
                                                  Disabled="_deletingSourceInstanceId == instance.Id">
                                        @(_deletingSourceInstanceId == instance.Id ? "Deleting..." : "Delete")
                                    </FluentButton>
                                    @foreach (var action in instance.Actions)
                                    {
                                        var capturedAction = action;
                                        var capturedInstance = instance;
                                        var isRunning = _executingActionInstanceId == instance.Id && _executingActionId == action.ActionId;
                                        <FluentButton Appearance="Appearance.Outline"
                                                      Title="@action.Hint"
                                                      OnClick="@(() => InvokePluginActionAsync(capturedInstance, capturedAction))"
                                                      Disabled="@isRunning">
                                            @(isRunning ? "Redirecting…" : action.Label)
                                        </FluentButton>
                                    }
                                </FluentStack>

                                @if (_sourceMessage is not null && _lastActionInstanceId == instance.Id)
                                {
                                    <FluentMessageBar Intent="@_sourceMessageIntent">@_sourceMessage</FluentMessageBar>
                                }
                            </FluentStack>
                        </section>
                    }
                </FluentStack>
            }
            else if (!_showAddForm)
            {
                <p>No calendar sources configured yet. Click <strong>+ Add Source</strong> to get started.</p>
            }
        </section>

        <section class="card">
            <h3>Obfuscation Profiles</h3>

            @foreach (var profile in _profiles)
            {
                <section class="card">
                    <h4>@profile.Context</h4>
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                        <FluentCheckbox @bind-Value="profile.RemoveTitle" Label="Remove title"/>
                        <FluentCheckbox @bind-Value="profile.RemoveDescription" Label="Remove description"/>
                        <FluentCheckbox @bind-Value="profile.RemoveLocation" Label="Remove location"/>
                        <FluentCheckbox @bind-Value="profile.RemoveAttendees" Label="Remove attendees"/>
                        <FluentCheckbox @bind-Value="profile.RoundTimes" Label="Round times"/>
                        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8"
                                     VerticalAlignment="VerticalAlignment.Center">
                            <FluentLabel>Rounding interval (minutes)</FluentLabel>
                            <FluentNumberField @bind-Value="profile.RoundingIntervalMinutes" Min="1" Max="60" />
                        </FluentStack>
                        <FluentCheckbox @bind-Value="profile.MergeBlocks" Label="Merge adjacent blocks"/>
                        <FluentButton Appearance="Appearance.Accent" OnClick="@(() => SaveProfileAsync(profile))">
                            Save
                        </FluentButton>
                    </FluentStack>
                </section>
            }

            @if (_profileMessage is not null)
            {
                <FluentMessageBar Intent="MessageIntent.Success">
                    @_profileMessage
                </FluentMessageBar>
            }
        </section>
    </FluentStack>
}
