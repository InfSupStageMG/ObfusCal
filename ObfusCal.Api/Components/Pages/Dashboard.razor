@page "/"
@attribute [Authorize]
@using Microsoft.JSInterop
@using ObfusCal.Application.Interfaces
@using ObfusCal.Application.UseCases.GetMergedFreeBusy
@using ObfusCal.Api.Authorization
@using ObfusCal.Api.Components.Shared
@inject IGetMergedFreeBusyUseCase GetMergedFreeBusyUseCase
@inject ICalendarOwnerService CalendarOwnerService
@inject ICalendarOwnerAvailabilitySyncService AvailabilitySyncService
@inject CurrentUserContextAccessor CurrentUserContextAccessor
@inject IJSRuntime Js

<PageTitle>Dashboard - ObfusCal</PageTitle>

<h1>Dashboard</h1>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
    @if (_accessMessage is not null)
    {
        <FluentMessageBar Intent="MessageIntent.Warning" Title="Calendar owner access required">
            @_accessMessage
        </FluentMessageBar>
    }

    <section class="card combined-calendar-card">
        <h3>Combined Calendar</h3>

        <div class="combined-calendar-controls" role="group" aria-label="Combined calendar filters">
            <div class="combined-calendar-field combined-calendar-field--owner app-form-field">
                <FluentLabel Class="combined-calendar-label app-form-label">Calendar Owner</FluentLabel>
                @if (_isSysadmin)
                {
                    <FluentSelect TOption="CalendarOwnerOption"
                                  Items="_calendarOwners"
                                  OptionValue="@(o => o.Id.ToString())"
                                  OptionText="@(o => o.Name)"
                                  Class="combined-calendar-control app-form-control"
                                  Style="width: 100%; max-width: 100%; min-width: 0;"
                                  @bind-SelectedOption="_selectedOwner" />
                }
                else
                {
                    <FluentTextField Value="@(_selectedOwner?.Name ?? "No mapped calendar owner")"
                                     ReadOnly="true"
                                     Class="combined-calendar-control app-form-control"
                                     Style="width: 100%; max-width: 100%; min-width: 0;" />
                }
            </div>

            <div class="combined-calendar-field combined-calendar-field--from app-form-field">
                <FluentLabel Class="combined-calendar-label app-form-label">From</FluentLabel>
                <FluentDatePicker @bind-Value="_fromDate" Class="combined-calendar-control app-form-control" Style="width: 100%; max-width: 100%; min-width: 0;" />
            </div>

            <div class="combined-calendar-field combined-calendar-field--to app-form-field">
                <FluentLabel Class="combined-calendar-label app-form-label">To</FluentLabel>
                <FluentDatePicker @bind-Value="_toDate" Class="combined-calendar-control app-form-control" Style="width: 100%; max-width: 100%; min-width: 0;" />
            </div>

            <div class="combined-calendar-field combined-calendar-field--timezone app-form-field">
                <FluentLabel Class="combined-calendar-label app-form-label">Time zone</FluentLabel>
                <FluentSelect TOption="TimeZoneOption"
                              Items="_timeZones"
                              OptionValue="@(tz => tz.Id)"
                              OptionText="@(tz => tz.DisplayName)"
                              Class="combined-calendar-control app-form-control"
                              Style="width: 100%; max-width: 100%; min-width: 0;"
                              @bind-SelectedOption="_selectedTimeZone" />
            </div>

            <div class="combined-calendar-actions app-form-actions">
                <FluentButton Appearance="Appearance.Accent" OnClick="LoadFreeBusyAsync" Disabled="_selectedOwner is null" Class="combined-calendar-button app-form-button">
                    Load
                </FluentButton>
                <FluentButton OnClick="RefreshAndLoadAsync" Disabled="_selectedOwner is null || _refreshing" Class="combined-calendar-button app-form-button">
                    @(_refreshing ? "Refreshing..." : "Refresh")
                </FluentButton>
            </div>
        </div>
    </section>

    @if (_loading)
    {
        <FluentProgress />
    }
    else if (_slots is { Count: > 0 })
    {
        <MergedFreeBusyCalendarView
            Slots="_slots"
            TimeZone="ResolveSelectedTimeZone()"
            DisplayDate="_fromDate" />
    }
    else if (_loaded)
    {
        <FluentMessageBar Intent="MessageIntent.Info" Title="No slots">
            No busy slots found for the selected period.
        </FluentMessageBar>
    }
</FluentStack>

@code {
    private List<CalendarOwnerOption>? _calendarOwners;
    private CalendarOwnerOption? _selectedOwner;
    private DateTime? _fromDate = DateTime.UtcNow.Date;
    private DateTime? _toDate = DateTime.UtcNow.Date.AddDays(7);
    private List<MergedFreeBusyResponse>? _slots;
    private bool _loading;
    private bool _loaded;
    private bool _refreshing;
    private bool _isSysadmin;
    private string? _accessMessage;

    private List<TimeZoneOption> _timeZones = [];
    private TimeZoneOption? _selectedTimeZone;
    private bool _timeZoneLookupStarted;
    private static string? _sCachedTimeZoneId;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;

        var currentUser = await CurrentUserContextAccessor.GetCurrentAsync();
        _isSysadmin = currentUser.IsSysadmin;

        if (_isSysadmin)
        {
            var owners = await CalendarOwnerService.ListAsync();
            _calendarOwners = owners.Select(o => new CalendarOwnerOption(o.Id, o.Name)).ToList();
        }
        else
        {
            if (string.IsNullOrWhiteSpace(currentUser.EntraObjectId))
            {
                _calendarOwners = [];
                _accessMessage = "Your signed-in session did not contain an Entra object ID.";
            }
            else if (currentUser.CalendarOwnerId is null || string.IsNullOrWhiteSpace(currentUser.CalendarOwnerName))
            {
                _calendarOwners = [];
                _accessMessage = "A calendar owner could not be provisioned for your signed-in account.";
            }
            else
            {
                _calendarOwners = [new CalendarOwnerOption(currentUser.CalendarOwnerId.Value, currentUser.CalendarOwnerName)];
            }
        }

        if (_calendarOwners.Count > 0)
            _selectedOwner = _calendarOwners[0];

        _timeZones = TimeZoneInfo.GetSystemTimeZones()
            .Select(tz => new TimeZoneOption(tz.Id, tz.DisplayName))
            .OrderBy(tz => tz.DisplayName, StringComparer.OrdinalIgnoreCase)
            .ToList();

        _selectedTimeZone = _timeZones.FirstOrDefault(tz =>
                                tz.Id.Equals(_sCachedTimeZoneId, StringComparison.OrdinalIgnoreCase))
                            ?? _timeZones.FirstOrDefault(tz => tz.Id == "UTC")
                            ?? _timeZones.FirstOrDefault();

        _loading = false;
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _timeZoneLookupStarted)
            return Task.CompletedTask;

        _timeZoneLookupStarted = true;
        _ = ResolveBrowserTimeZoneAsync();
        return Task.CompletedTask;
    }

    private async Task ResolveBrowserTimeZoneAsync()
    {
        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromMilliseconds(750));
            var browserTimeZone = await Js.InvokeAsync<string?>(
                "obfusCalTime.getCachedOrBrowserTimeZone",
                cts.Token);
            if (string.IsNullOrWhiteSpace(browserTimeZone))
                return;

            _sCachedTimeZoneId = browserTimeZone;

            var option = _timeZones.FirstOrDefault(tz => tz.Id.Equals(browserTimeZone, StringComparison.OrdinalIgnoreCase));
            if (option is null || Equals(option, _selectedTimeZone))
                return;

            _selectedTimeZone = option;
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException)
        {
            // Never block UI if JS timezone detection stalls.
        }
        catch (JSException)
        {
            // Keep UTC when browser timezone detection is unavailable.
        }
    }

    private async Task LoadFreeBusyAsync()
    {
        if (_selectedOwner is null || _fromDate is null || _toDate is null)
            return;

        _loading = true;
        _loaded = false;
        _slots = null;

        try
        {
            var timeZone = ResolveSelectedTimeZone();
            var from = ConvertLocalDateBoundaryToUtc(_fromDate.Value.Date, timeZone);
            var to = ConvertLocalDateBoundaryToUtc(_toDate.Value.Date.AddDays(1), timeZone);

            var result = await GetMergedFreeBusyUseCase.ExecuteAsync(
                new GetMergedFreeBusyQuery(_selectedOwner.Id, from, to),
                CancellationToken.None);
            _slots = result.ToList();
        }
        finally
        {
            _loading = false;
            _loaded = true;
        }
    }

    private async Task RefreshAndLoadAsync()
    {
        if (_selectedOwner is null)
            return;

        _refreshing = true;
        try
        {
            await AvailabilitySyncService.RunSyncForOwnerAsync(_selectedOwner.Id, CancellationToken.None);
            await LoadFreeBusyAsync();
        }
        finally
        {
            _refreshing = false;
        }
    }

    private TimeZoneInfo ResolveSelectedTimeZone()
    {
        if (_selectedTimeZone is null)
            return TimeZoneInfo.Utc;

        try
        {
            return TimeZoneInfo.FindSystemTimeZoneById(_selectedTimeZone.Id);
        }
        catch (TimeZoneNotFoundException)
        {
            return TimeZoneInfo.Utc;
        }
        catch (InvalidTimeZoneException)
        {
            return TimeZoneInfo.Utc;
        }
    }

    private static DateTimeOffset ConvertLocalDateBoundaryToUtc(DateTime localDate, TimeZoneInfo timeZone)
    {
        var local = DateTime.SpecifyKind(localDate, DateTimeKind.Unspecified);
        var utc = TimeZoneInfo.ConvertTimeToUtc(local, timeZone);
        return new DateTimeOffset(utc, TimeSpan.Zero);
    }


    private sealed record CalendarOwnerOption(Guid Id, string Name);
    private sealed record TimeZoneOption(string Id, string DisplayName);
}
