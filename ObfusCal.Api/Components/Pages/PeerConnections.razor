@page "/peers"
@attribute [Authorize]
@using ObfusCal.Application.Interfaces
@using ObfusCal.Api.Authorization
@inject ICalendarOwnerService CalendarOwnerService
@inject IPeerConnectionService PeerConnectionService
@inject CurrentUserContextAccessor CurrentUserContextAccessor

<PageTitle>@(_isSysadmin ? "Peer Connections - ObfusCal" : "My Peers - ObfusCal")</PageTitle>

<h1>@(_isSysadmin ? "Peer Connections" : "My Peers")</h1>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
    @if (_accessMessage is not null)
    {
        <FluentMessageBar Intent="MessageIntent.Warning" Title="Peer visibility unavailable">
            @_accessMessage
        </FluentMessageBar>
    }

    @if (_loading)
    {
        <FluentProgress />
    }
    else if (_isSysadmin)
    {
        <section class="card">
            <h3>Admin responsibilities</h3>
            <p class="peer-section-description">
                Peer connectivity is an operator-managed capability. Sysadmins create or delete instance-level peers and decide which
                calendar owners are linked to each approved peer.
            </p>
        </section>

        <section class="card">
            <h3>Add Peer Connection</h3>
            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Bottom" Wrap="true" Class="peer-add-row app-form-row">
                <FluentTextField @bind-Value="_newInstanceId" Immediate="true" Placeholder="Instance ID (e.g. obfuscal-partner)" Class="peer-instance-input app-form-item app-form-control" Style="width: 100%; max-width: 100%; min-width: 0;" />
                <FluentTextField @bind-Value="_newBaseAddress" Immediate="true" Placeholder="https://partner.example.com" Class="peer-base-address-input app-form-item app-form-control" Style="width: 100%; max-width: 100%; min-width: 0;" />
                <FluentTextField @bind-Value="_newApiKey" Immediate="true" Placeholder="API Key" Class="peer-api-key-input app-form-item app-form-control" Style="width: 100%; max-width: 100%; min-width: 0;" />
                <FluentButton Appearance="Appearance.Accent" OnClick="AddPeerAsync"
                              Disabled="@(string.IsNullOrWhiteSpace(_newInstanceId) || string.IsNullOrWhiteSpace(_newBaseAddress) || string.IsNullOrWhiteSpace(_newApiKey))" Class="peer-add-button app-form-button">
                    Add Peer
                </FluentButton>
            </FluentStack>
            @if (_message is not null)
            {
                <FluentMessageBar Intent="@_messageIntent" Class="card-message">
                    @_message
                </FluentMessageBar>
            }
        </section>

        @if (_adminPeers is not null)
        {
            <section class="card">
                <h3>Configured Peers</h3>
                @if (_adminPeers.Count == 0)
                {
                    <p>No peer connections configured. Add one above to enable cross-domain sync.</p>
                }
                else
                {
                    <FluentDataGrid Items="_adminPeers.AsQueryable()" TGridItem="PeerConnectionSummary" Class="app-data-grid">
                        <PropertyColumn Property="@(p => p.InstanceId)" Title="Instance ID" Sortable="true" />
                        <PropertyColumn Property="@(p => p.BaseAddress)" Title="Base Address" />
                        <PropertyColumn Property="@(p => p.MappingCount)" Title="Owner Mappings" />
                        <TemplateColumn Title="Actions">
                            <FluentButton Appearance="Appearance.Outline" OnClick="@(() => DeletePeerAsync(context.Id))">
                                Delete
                            </FluentButton>
                        </TemplateColumn>
                    </FluentDataGrid>
                }
            </section>

            <section class="card">
                <h3>Link Owner to Peer</h3>
                <p class="link-section-description">Map a calendar owner to a peer so their busy slots are synced to that peer.</p>
                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Bottom" Wrap="true" Class="peer-link-row app-form-row">
                    <div class="peer-select-field app-form-field">
                        <FluentLabel Class="app-form-label">Calendar Owner</FluentLabel>
                        <FluentSelect TOption="OwnerOption"
                                      Items="_owners"
                                      OptionValue="@(o => o.Id.ToString())"
                                      OptionText="@(o => o.Name)"
                                      Class="peer-owner-select app-form-control"
                                      Style="width: 100%; max-width: 100%; min-width: 0;"
                                      @bind-SelectedOption="_selectedOwner" />
                    </div>
                    <div class="peer-select-field app-form-field">
                        <FluentLabel Class="app-form-label">Peer</FluentLabel>
                        <FluentSelect TOption="PeerOption"
                                      Items="_peerOptions"
                                      OptionValue="@(p => p.Id.ToString())"
                                      OptionText="@(p => p.InstanceId)"
                                      Class="peer-peer-select app-form-control"
                                      Style="width: 100%; max-width: 100%; min-width: 0;"
                                      @bind-SelectedOption="_selectedPeer" />
                    </div>
                    <FluentButton Appearance="Appearance.Accent" OnClick="LinkOwnerToPeerAsync"
                                  Disabled="@(_selectedOwner is null || _selectedPeer is null)" Class="peer-link-button app-form-button">
                        Link
                    </FluentButton>
                </FluentStack>
                @if (_linkMessage is not null)
                {
                    <FluentMessageBar Intent="@_linkMessageIntent" Class="card-message">
                        @_linkMessage
                    </FluentMessageBar>
                }
            </section>
        }
    }
    else
    {
        <section class="card">
            <h3>Peer visibility</h3>
            <p class="peer-section-description">
                Peer onboarding is handled by administrators. This page shows the peer requests and approved peer connections that are
                associated with your calendar owner.
            </p>

            @if (_userPeerConnections is { Count: > 0 })
            {
                <FluentDataGrid Items="_userPeerConnections.AsQueryable()" TGridItem="UserPeerConnectionRow" Class="app-data-grid">
                    <PropertyColumn Property="@(p => p.ClientOrganisationName)" Title="Client / Peer" Sortable="true" />
                    <TemplateColumn Title="Status">
                        @switch (context.Status)
                        {
                            case PeerConnectionStatus.Active:
                                <FluentBadge Appearance="Appearance.Accent" Color="Color.Success">Active</FluentBadge>
                                break;
                            case PeerConnectionStatus.Requested:
                                <FluentBadge Appearance="Appearance.Accent" Color="Color.Warning">Requested</FluentBadge>
                                break;
                            default:
                                <FluentBadge Appearance="Appearance.Neutral">Suspended</FluentBadge>
                                break;
                        }
                    </TemplateColumn>
                </FluentDataGrid>
            }
            else
            {
                <FluentMessageBar Intent="MessageIntent.Info" Title="No peers yet">
                    No peer requests or peer connections are currently linked to your calendar owner.
                </FluentMessageBar>
            }
        </section>
    }
</FluentStack>

@code {
    private List<PeerConnectionSummary>? _adminPeers;
    private List<UserPeerConnectionRow>? _userPeerConnections;
    private List<OwnerOption>? _owners;
    private List<PeerOption>? _peerOptions;
    private bool _loading = true;
    private bool _isSysadmin;
    private Guid? _currentCalendarOwnerId;
    private string? _accessMessage;

    private string? _newInstanceId;
    private string? _newBaseAddress;
    private string? _newApiKey;
    private string? _message;
    private MessageIntent _messageIntent = MessageIntent.Info;

    private OwnerOption? _selectedOwner;
    private PeerOption? _selectedPeer;
    private string? _linkMessage;
    private MessageIntent _linkMessageIntent = MessageIntent.Info;

    protected override async Task OnInitializedAsync()
    {
        var currentUser = await CurrentUserContextAccessor.GetCurrentAsync();
        _isSysadmin = currentUser.IsSysadmin;
        _currentCalendarOwnerId = currentUser.CalendarOwnerId;

        if (_isSysadmin)
        {
            await LoadAdminDataAsync();
            return;
        }

        if (_currentCalendarOwnerId is null)
        {
            _accessMessage = "A calendar owner could not be resolved for your signed-in account.";
            _loading = false;
            return;
        }

        await LoadUserDataAsync();
    }

    private async Task LoadAdminDataAsync()
    {
        _adminPeers = (await PeerConnectionService.ListAsync()).ToList();

        var ownerSummaries = await CalendarOwnerService.ListAsync();
        _owners = ownerSummaries.Select(o => new OwnerOption(o.Id, o.Name)).ToList();
        _peerOptions = _adminPeers.Select(p => new PeerOption(p.Id, p.InstanceId)).ToList();

        _selectedOwner ??= _owners.FirstOrDefault();
        _selectedPeer ??= _peerOptions.FirstOrDefault();


        _loading = false;
    }

    private async Task LoadUserDataAsync()
    {
        if (_currentCalendarOwnerId is null)
        {
            _userPeerConnections = [];
            _loading = false;
            return;
        }

        _userPeerConnections = (await PeerConnectionService.ListForCalendarOwnerAsync(_currentCalendarOwnerId.Value))
            .Select(connection => new UserPeerConnectionRow(connection.Id, connection.ClientOrganisationName, connection.Status))
            .ToList();

        _loading = false;
    }

    private async Task AddPeerAsync()
    {
        _message = null;
        if (string.IsNullOrWhiteSpace(_newInstanceId) || string.IsNullOrWhiteSpace(_newBaseAddress) || string.IsNullOrWhiteSpace(_newApiKey))
            return;

        await PeerConnectionService.CreateAsync(_newInstanceId, _newBaseAddress, _newApiKey);

        _message = $"Peer '{_newInstanceId.Trim()}' added.";
        _messageIntent = MessageIntent.Success;
        _newInstanceId = null;
        _newBaseAddress = null;
        _newApiKey = null;

        await LoadAdminDataAsync();
    }

    private async Task DeletePeerAsync(Guid peerId)
    {
        _message = null;
        var deleted = await PeerConnectionService.DeleteAsync(peerId);
        _message = deleted ? "Peer removed." : "Peer not found.";
        _messageIntent = deleted ? MessageIntent.Success : MessageIntent.Error;
        await LoadAdminDataAsync();
    }

    private async Task LinkOwnerToPeerAsync()
    {
        _linkMessage = null;
        if (_selectedOwner is null || _selectedPeer is null) return;

        var result = await PeerConnectionService.LinkOwnerToPeerAsync(_selectedOwner.Id, _selectedPeer.Id);
        switch (result.Outcome)
        {
            case LinkOwnerToPeerOutcome.Linked:
                _linkMessage = $"Linked '{_selectedOwner.Name}' to '{_selectedPeer.InstanceId}' (ref: {result.CalendarOwnerRef}).";
                _linkMessageIntent = MessageIntent.Success;
                await LoadAdminDataAsync();
                break;
            case LinkOwnerToPeerOutcome.AlreadyLinked:
                _linkMessage = "This owner is already linked to this peer.";
                _linkMessageIntent = MessageIntent.Warning;
                break;
            default:
                _linkMessage = "Failed to link.";
                _linkMessageIntent = MessageIntent.Error;
                break;
        }
    }

    private sealed record OwnerOption(Guid Id, string Name);
    private sealed record PeerOption(Guid Id, string InstanceId);
    private sealed record UserPeerConnectionRow(Guid Id, string ClientOrganisationName, PeerConnectionStatus Status);
}
