@page "/consent-callback"
@rendermode ConsentCallback.RenderMode
@attribute [Authorize]
@using ObfusCal.Application.Interfaces
@using System.Collections.Concurrent
@using Microsoft.Extensions.Logging
@inject ICalendarOwnerGoogleConsentService GoogleConsentService
@inject ICalendarOwnerGraphConsentService GraphConsentService
@inject NavigationManager Navigation
@inject ILogger<ConsentCallback> Logger

<PageTitle>Authorizing… - ObfusCal</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="16" Class="consent-container">
    @if (_loading)
    {
        <FluentProgress />
        <p>Completing authorization, please wait…</p>
    }
    else if (_errorMessage is not null)
    {
        <FluentMessageBar Intent="MessageIntent.Error">
            <strong>Authorization failed:</strong> @_errorMessage
        </FluentMessageBar>
    }
    else
    {
        <FluentMessageBar Intent="MessageIntent.Success">
            ✓ Authorization completed successfully. You can now close this window.
        </FluentMessageBar>
    }
</FluentStack>

@code {
    private const string GraphStatePrefix = "graph.";
    private static readonly ConcurrentDictionary<string, byte> ProcessedStates = new(StringComparer.Ordinal);

    [Parameter, SupplyParameterFromQuery] public string? Code { get; set; }
    [Parameter, SupplyParameterFromQuery] public string? State { get; set; }

    private bool _loading = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        // Guard: skip all OAuth work during server-side prerendering.
        // The consent callback MUST run in the interactive circuit so the circuit-scoped
        // AppDbContext remains alive through the exchange → token-save sequence.
        // The component already has prerender:false, but the parent Routes component
        // (InteractiveServer / prerender:true) cascades its prerender setting to children,
        // so RendererInfo.IsInteractive is the definitive, cascade-immune guard.
        // Returning here keeps _loading=true; the circuit re-render will show the real result.
        if (!RendererInfo.IsInteractive)
            return;

        var shouldReleaseState = false;
        string? stateToken = null;

        try
        {
            if (string.IsNullOrWhiteSpace(Code))
            {
                _errorMessage = "No authorization code was returned by the provider.";
                return;
            }

            if (string.IsNullOrWhiteSpace(State))
            {
                _errorMessage = "Authorization state was not provided.";
                return;
            }

            stateToken = State;
            if (!ProcessedStates.TryAdd(stateToken, 0))
            {
                Logger.LogInformation("Skipping duplicate consent callback for state token.");
                return;
            }

            shouldReleaseState = true;

            var isGraphConsent = State.StartsWith(GraphStatePrefix, StringComparison.Ordinal);

            try
            {
                if (isGraphConsent)
                {
                    await GraphConsentService.CompleteConsentFromStateAsync(Code, State);
                }
                else
                {
                    await GoogleConsentService.CompleteConsentFromStateAsync(Code, State);
                }

                shouldReleaseState = false; // keep state locked so duplicate callbacks are no-ops
            }
            catch (InvalidOperationException ex) when (IsStateValidationFailure(ex.Message))
            {
                Logger.LogWarning(ex, "State validation failed during consent completion");
                _errorMessage = "Authorization from the provider could not be validated.";
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Unexpected error during consent completion. Exception type: {ExceptionType}", ex.GetType().Name);
                _errorMessage = ex.InnerException?.Message ?? ex.Message;
            }
        }
        finally
        {
            if (shouldReleaseState && stateToken is not null)
                ProcessedStates.TryRemove(stateToken, out _);

            _loading = false;
        }
    }

    // Detects exceptions thrown by the Google/Graph state-validation logic.
    // Using precise phrases prevents infrastructure exceptions such as EF Core's
    // ObjectDisposedException (whose message contains "…using statement…", where
    // "statement" starts with "state") from being silently swallowed as state errors.
    internal static bool IsStateValidationFailure(string message)
        => message.Contains("consent state", StringComparison.OrdinalIgnoreCase)
           || message.StartsWith("State is required", StringComparison.OrdinalIgnoreCase);
}

