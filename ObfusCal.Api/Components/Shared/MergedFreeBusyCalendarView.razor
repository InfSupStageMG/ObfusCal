@using System.Globalization
@using ObfusCal.Application.UseCases.GetMergedFreeBusy

<section class="card calendar-view">
    <div class="calendar-grid">
        <div class="calendar-header">
            <div class="calendar-header-row">
                <div class="calendar-month-nav">
                    <button class="month-nav-btn" @onclick="PreviousMonth" aria-label="Previous month">&#8249;</button>
                    <h3 class="calendar-month-label">@_monthYear</h3>
                    <button class="month-nav-btn" @onclick="NextMonth" aria-label="Next month">&#8250;</button>
                </div>
                @if (Slots.Count > 0)
                {
                    <div class="calendar-date-range">
                        <span class="date-range-label">Data:</span>
                        <span class="date-range-value">@GetDisplayDateRange()</span>
                    </div>
                }
            </div>
        </div>

        <div class="calendar-weekdays">
            @foreach (var day in new[] { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" })
            {
                <div class="calendar-weekday">@day</div>
            }
        </div>

        <div class="calendar-dates">
            @foreach (var (date, hasEvents, events) in _calendarDays)
            {
                var isOutsideViewMonth = IsOutsideViewMonth(date);
                var isSelectable = date.HasValue && !isOutsideViewMonth;

                <div class="calendar-day @(hasEvents ? "has-events" : "") @(isOutsideViewMonth ? "other-month" : "") @(date == _selectedDate ? "selected" : "")"
                     @onclick="@(() => SelectDay(date))"
                     role="@(isSelectable ? "button" : null)"
                     tabindex="@(isSelectable ? 0 : -1)"
                     style="cursor: @(isSelectable ? "pointer" : "default");">
                    @if (date.HasValue)
                    {
                        <div class="calendar-day-number">@date.Value.Day</div>
                        @if (hasEvents && events.Count > 0)
                        {
                            <div class="calendar-day-events">
                                @foreach (var evt in events.Take(2))
                                {
                                    <div class="calendar-event-badge" title="@(evt.Title ?? "Busy") - @FormatTime(evt) to @FormatEndTime(evt)">
                                        <span class="event-time">@FormatTime(evt)-@FormatEndTime(evt)</span>
                                    </div>
                                }
                                @if (events.Count > 2)
                                {
                                    <div class="calendar-event-badge more">+@(events.Count - 2)</div>
                                }
                            </div>
                        }
                    }
                </div>
            }
        </div>
    </div>
</section>

@if (_showModal && _selectedDate.HasValue && _selectedDayEvents.Count > 0)
{
    var selectedDate = _selectedDate.GetValueOrDefault();
    <div class="modal-backdrop" @onclick="CloseModal"></div>
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <div class="modal-header-content">
                    <h2>@selectedDate.ToString("dddd, dd MMMM yyyy", CultureInfo.CurrentCulture)</h2>
                    <span class="modal-event-count">@_selectedDayEvents.Count @(_selectedDayEvents.Count == 1 ? "event" : "events")</span>
                </div>
                <button class="modal-close" @onclick="CloseModal" aria-label="Close">
                    <span>×</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="events-list">
                    @foreach (var evt in _selectedDayEvents)
                    {
                        <div class="event-item">
                            <div class="event-item-header">
                                <div class="event-time-range">
                                    <strong>@FormatInTimeZone(evt.Start, "HH:mm")</strong>
                                    <span class="event-separator">–</span>
                                    <strong>@FormatInTimeZone(evt.End, "HH:mm")</strong>
                                    <span class="event-duration">(@CalculateDuration(evt))</span>
                                </div>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(evt.Title))
                            {
                                <div class="event-title">@evt.Title</div>
                            }
                            else
                            {
                                <div class="event-title event-title--empty">(Busy)</div>
                            }
                            <div class="event-meta">
                                @if (!string.IsNullOrWhiteSpace(evt.Location))
                                {
                                    <div class="event-detail">
                                        <span class="event-detail-icon">📍</span>
                                        <span class="event-detail-text">@evt.Location</span>
                                    </div>
                                }
                                @if (evt.AttendeeEmails?.Count > 0)
                                {
                                    <div class="event-detail">
                                        <span class="event-detail-icon">👥</span>
                                        <span class="event-detail-text event-detail-text--attendees">@string.Join(", ", evt.AttendeeEmails)</span>
                                    </div>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(evt.Description))
                            {
                                <div class="event-description">@evt.Description</div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public required List<MergedFreeBusyResponse> Slots { get; set; }

    [Parameter]
    public required TimeZoneInfo TimeZone { get; set; }

    [Parameter]
    public DateTime? DisplayDate { get; set; } = DateTime.UtcNow;

    private string _monthYear = "";
    private List<(DateTime? Date, bool HasEvents, List<MergedFreeBusyResponse> Events)> _calendarDays = [];
    private List<MergedFreeBusyResponse> _selectedDayEvents = [];
    private DateTime? _selectedDate;
    private bool _showModal;

    private DateTime _viewMonth = DateTime.Today;
    private List<MergedFreeBusyResponse>? _lastSeenSlots;
    private DateTime? _lastDisplayDate;

    protected override void OnParametersSet()
    {
        var nextDisplayDate = DisplayDate?.Date ?? DateTime.Today;

        if (!ReferenceEquals(_lastSeenSlots, Slots) || _lastDisplayDate != nextDisplayDate)
        {
            _viewMonth = nextDisplayDate;
            _lastSeenSlots = Slots;
            _lastDisplayDate = nextDisplayDate;
            _selectedDate = null;
            _selectedDayEvents = [];
            _showModal = false;
        }

        BuildCalendarGrid();
    }

    private void PreviousMonth()
    {
        _viewMonth = _viewMonth.AddMonths(-1);
        BuildCalendarGrid();
    }

    private void NextMonth()
    {
        _viewMonth = _viewMonth.AddMonths(1);
        BuildCalendarGrid();
    }

    private void SelectDay(DateTime? date)
    {
        if (IsOutsideViewMonth(date))
            return;

        var selectedDate = date.GetValueOrDefault();

        _selectedDate = selectedDate;
        _selectedDayEvents = GetEventsForDate(selectedDate);
        _showModal = _selectedDayEvents.Count > 0;
    }

    private void CloseModal()
    {
        _showModal = false;
        _selectedDate = null;
        _selectedDayEvents = [];
    }

    private void BuildCalendarGrid()
    {
        var firstDay = new DateTime(_viewMonth.Year, _viewMonth.Month, 1);
        _monthYear = firstDay.ToString("MMMM yyyy", CultureInfo.CurrentCulture);

        _calendarDays = [];

        // Add days from previous month
        var startDayOfWeek = (int)firstDay.DayOfWeek;

        for (var i = startDayOfWeek - 1; i >= 0; i--)
        {
            var date = new DateTime(firstDay.Year, firstDay.Month, 1).AddDays(-i - 1);
            _calendarDays.Add((date, false, []));
        }

        // Add days of current month
        var daysInMonth = DateTime.DaysInMonth(firstDay.Year, firstDay.Month);
        for (var day = 1; day <= daysInMonth; day++)
        {
            var date = new DateTime(firstDay.Year, firstDay.Month, day);
            var eventsOnDay = GetEventsForDate(date);
            _calendarDays.Add((date, eventsOnDay.Count > 0, eventsOnDay));
        }

        // Add days from next month to fill grid
        var remainingCells = 42 - _calendarDays.Count; // 6 weeks * 7 days
        for (var i = 1; i <= remainingCells; i++)
        {
            var date = new DateTime(firstDay.Year, firstDay.Month, daysInMonth).AddDays(i);
            _calendarDays.Add((date, false, []));
        }
    }

    private List<MergedFreeBusyResponse> GetEventsForDate(DateTime date)
    {
        if (Slots.Count == 0)
            return [];

        return Slots
            .Where(s =>
            {
                var startInTz = TimeZoneInfo.ConvertTime(s.Start, TimeZone);
                var endInTz = TimeZoneInfo.ConvertTime(s.End, TimeZone);
                var startDate = startInTz.Date;
                var endDate = endInTz.Date;

                // Event spans across this date or starts on this date
                return (startDate <= date && endDate >= date) ||
                       (startDate >= date && startDate <= date);
            })
            .OrderBy(s => TimeZoneInfo.ConvertTime(s.Start, TimeZone))
            .ToList();
    }

    private bool IsOutsideViewMonth(DateTime? date)
        => !date.HasValue || date.Value.Month != _viewMonth.Month || date.Value.Year != _viewMonth.Year;

    private string FormatTime(MergedFreeBusyResponse evt)
    {
        var time = TimeZoneInfo.ConvertTime(evt.Start, TimeZone);
        return time.ToString("HH:mm", CultureInfo.CurrentCulture);
    }

    private string FormatEndTime(MergedFreeBusyResponse evt)
    {
        var time = TimeZoneInfo.ConvertTime(evt.End, TimeZone);
        return time.ToString("HH:mm", CultureInfo.CurrentCulture);
    }

    private string FormatInTimeZone(DateTimeOffset value, string format)
    {
        var local = TimeZoneInfo.ConvertTime(value, TimeZone);
        return local.ToString(format, CultureInfo.CurrentCulture);
    }

    private string GetDisplayDateRange()
    {
        if (Slots.Count == 0)
            return "No data";

        var minDate = Slots.Min(s => TimeZoneInfo.ConvertTime(s.Start, TimeZone).Date);
        var maxDate = Slots.Max(s => TimeZoneInfo.ConvertTime(s.End, TimeZone).Date);

        return $"{minDate:d MMM yyyy} – {maxDate:d MMM yyyy}";
    }

    private string CalculateDuration(MergedFreeBusyResponse evt)
    {
        var duration = evt.End - evt.Start;
        if (duration.TotalHours >= 1)
        {
            var hours = (int)duration.TotalHours;
            var minutes = duration.Minutes;
            return minutes > 0 ? $"{hours}h {minutes}m" : $"{hours}h";
        }
        else
        {
            return $"{duration.Minutes}m";
        }
    }
}
