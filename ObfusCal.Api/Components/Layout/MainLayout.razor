@inherits LayoutComponentBase
@using FluentIcons = Microsoft.FluentUI.AspNetCore.Components.Icons

<FluentDesignTheme Mode="DesignThemeModes.Light" CustomColor="#0078d4" />

<FluentLayout>
    <FluentHeader>
        ObfusCal
    </FluentHeader>

    <FluentStack Orientation="Orientation.Horizontal" Style="height: calc(100vh - 50px);">
        <FluentNavMenu Width="250" Title="Navigation" Style="background: var(--neutral-layer-2); border-right: 1px solid var(--neutral-stroke-divider-rest);">
            <FluentNavLink Href="/" Icon="@(new FluentIcons.Regular.Size20.CalendarLtr())" Match="NavLinkMatch.All">
                Dashboard
            </FluentNavLink>
            <FluentNavLink Href="/calendar-owners" Icon="@(new FluentIcons.Regular.Size20.People())">
                Calendar Owners
            </FluentNavLink>
            <FluentNavLink Href="/peers" Icon="@(new FluentIcons.Regular.Size20.Globe())">
                Peer Connections
            </FluentNavLink>
            <FluentNavLink Href="/sync-status" Icon="@(new FluentIcons.Regular.Size20.ArrowSync())">
                Sync Status
            </FluentNavLink>
            <FluentNavLink Href="/health-status" Icon="@(new FluentIcons.Regular.Size20.HeartPulse())">
                Health Status
            </FluentNavLink>
        </FluentNavMenu>

        <FluentBodyContent Style="padding: 1.5rem; overflow-y: auto; flex: 1;">
            @Body
        </FluentBodyContent>
    </FluentStack>
</FluentLayout>

<FluentToastProvider />
<FluentDialogProvider />





