POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=obfuscal
CONNECTIONSTRINGS__DEFAULTCONNECTION=Host=localhost;Database=obfuscal;Username=postgres;Password=[DB_PASSWORD_HERE]

AZUREAD__TENANTID=[AZURE_AD_TENANT_ID]
AZUREAD__CLIENTID=[AZURE_AD_CLIENT_ID]
AZUREAD__CLIENTSECRET=[AZURE_AD_CLIENT_SECRET]
GRAPHCONSENT__CLIENTID=[GRAPH_CLIENT_ID]
GRAPHCONSENT__CLIENTSECRET=[GRAPH_CLIENT_SECRET]
GOOGLECONSENT__CLIENTID=[GOOGLE_CLIENT_ID]
GOOGLECONSENT__CLIENTSECRET=[GOOGLE_CLIENT_SECRET]
GOOGLECONSENT__REDIRECTURI=[GOOGLE_REDIRECT_URI]
SYNC__INSTANCEID=[SYNC_INSTANCE_ID]
SYNC__APIKEY=[SYNC_API_KEY]
SYNC__PEERREQUESTTIMESTAMPTOLERANCESECONDS=300
SYNC__PEERREQUESTRATELIMITPERMITLIMIT=240
SYNC__PEERREQUESTRATELIMITWINDOWSECONDS=60
SYNC__PUSHSHADOWSLOTSRATELIMITPERMITLIMIT=60
SYNC__PUSHSHADOWSLOTSRATELIMITWINDOWSECONDS=60
SYNC__PULLBUSYSLOTSRATELIMITPERMITLIMIT=120
SYNC__PULLBUSYSLOTSRATELIMITWINDOWSECONDS=60
SYNC__MAXQUERYWINDOWDAYS=90
SYNC__MAXSHADOWSLOTSPERREQUEST=500
SYNC__MAXREQUESTBODYSIZEBYTES=1048576
SYNC__SHADOWSLOTRETENTIONDAYS=90

# Application-layer column encryption key (AES-256-GCM).
# Must be a base64-encoded 256-bit (32-byte) random key.
# Generate with: openssl rand -base64 32
COLUMNENCRYPTION__KEY=[COLUMN_ENCRYPTION_KEY_HERE]

PEERTRANSPORTSECURITY__ALLOWSELFSIGNEDCERTS=false

API_CERT_PASSWORD=[API_CERT_PASSWORD_HERE]
